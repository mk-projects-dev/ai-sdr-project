# Публичный URL бэкенда FastAPI (браузер → API; не секрет).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Локализация: при NEXT_PUBLIC_REMOTE_I18N=false отключён онлайн-доперевод отсутствующих строк RU (MyMemory).
# По умолчанию в коде считается включённым, если переменная не задана.
# NEXT_PUBLIC_REMOTE_I18N=false
