# Database (async SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://aisdr:aisdr@localhost:5432/aisdr

# CORS (comma-separated origins for the Next.js app)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT (generate a long random string for production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Optional: create or update admin on application startup (single-tenant bootstrap)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me

# Anthropic (Фаза 4 — генерация писем)
ANTHROPIC_API_KEY=
# Имя модели в API (при ошибке «model not found» замените на актуальный ID из документации Anthropic)
ANTHROPIC_MODEL=claude-4.6-sonnet

# SMTP — отправка писем (при OUTREACH_DRY_RUN=true почта не шлётся, но лиды обрабатываются в БД)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

OUTREACH_DRY_RUN=false
WORKER_POLL_INTERVAL_SECONDS=25
WORKER_BATCH_SIZE=3

# IMAP (Фаза 5 — входящие ответы; нужны ANTHROPIC_API_KEY и доступ к ящику)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_USE_SSL=true
IMAP_POLL_INTERVAL_SECONDS=90
